{
	"name": "disteladvisory-website",
	"version": "0.1.0",
	"private": true,
	"description": "Marketing website for Distel Advisory",
	"homepage": "https://disteladvisory.com",
	"type": "module",
	"packageManager": "pnpm@10.11.0",
	"scripts": {
		"dev": "vite dev",
		"build": "pnpm prebuild && vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check .",
		"format": "prettier --write .",
		"prebuild": "node scripts/generate-build-info.js && node scripts/generate-sitemap.js",
		"prod:build": "pnpm prebuild && vite build",
		"prod:deploy:copy": "rsync -avz --delete -e 'ssh' ./* homelab:~/ssd-2tb/apps/michael/disteladvisory-website --include-from='prod.deploy.files.txt' --exclude '*'",
		"prod:deploy:run": "ssh homelab 'cd ~/ssd-2tb/apps/michael/disteladvisory-website && docker compose -f prod.compose.yml down && docker compose -f prod.compose.yml up -d'",
		"prod:deploy": "pnpm prod:build && pnpm prod:deploy:copy && pnpm prod:deploy:run"
	},
	"devDependencies": {
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.55.0",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/postcss": "^4.2.1",
		"@tailwindcss/vite": "^4.2.1",
		"autoprefixer": "^10.4.27",
		"postcss": "^8.5.8",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"svelte": "^5.53.12",
		"svelte-check": "^4.4.5",
		"tailwindcss": "^4.2.1",
		"tslib": "^2.8.1",
		"typescript": "^5.9.3",
		"vite": "^6.4.1"
	}
}
